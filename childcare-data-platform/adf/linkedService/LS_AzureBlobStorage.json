{
    "name": "LS_AzureBlobStorage",
    "type": "Microsoft.DataFactory/factories/linkedservices",
    "properties": {
        "type": "AzureBlobStorage",
        "typeProperties": {
            "connectionString": {
                "type": "AzureKeyVaultSecret",
                "store": {
                    "referenceName": "LS_KeyVault",
                    "type": "LinkedServiceReference",
                    "parameters": {
                        "keyVaultBaseUrl": {
                            "value": "@pipeline().globalParameters.keyVaultBaseUrl",
                            "type": "Expression"
                        }
                    }
                },
                "secretName": "storage-connection-string"
            }
        },
        "annotations": ["parameterized", "keyvault-backed"]
    }
}